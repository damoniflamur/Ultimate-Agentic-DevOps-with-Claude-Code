{
  "mcpServers": {
    "terraform": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-v", "/Users/fd-ks-c4fx0xr7hq/Desktop/onna/Ultimate-Agentic-DevOps-with-Claude-Code/terraform:/workspace",
        "-w", "/workspace",
        "hashicorp/terraform-mcp-server"
      ]
    },
    "aws": {
      "command": "uvx",
      "args": [
        "awslabs.aws-api-mcp-server@latest"
      ],
      "env": {}
    },
    "kubernetes": {
      "command": "npx",
      "args": [
        "-y",
        "kubernetes-mcp-server"
      ]
    }
  }
}
